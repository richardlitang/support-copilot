# App
NODE_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_DEBUG_RAG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_copilot

# Redis / Queue
REDIS_URL=redis://localhost:6379

# Local upload storage
UPLOAD_DIR=uploads

# Optional Supabase hosted mode
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=

# AI providers
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANSWER_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434

# Optional reranking
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v4.0-fast

# Observability
SENTRY_DSN=
LOG_LEVEL=info

# Security / limits
MAX_UPLOAD_MB=10
DEBUG_MODE=true

# Retrieval
SUPPORT_MATCH_THRESHOLD=0.46
SUPPORT_RETRIEVAL_TOP_K=8
SUPPORT_RETRIEVAL_CANDIDATE_TOP_K=30
