{
  "name": "support-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "worker:dev": "node --import tsx src/server/queue/workers/index.ts",
    "worker:start": "node --import tsx src/server/queue/workers/index.ts",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node --import tsx scripts/apply-migrations.ts",
    "seed:demo": "node --import tsx scripts/seed-demo.ts",
    "eval:demo": "node --import tsx scripts/run-evals.ts",
    "eval:demo:offline": "node --import tsx scripts/run-evals.ts --offline",
    "eval:rag-contract": "npm run eval:demo:offline",
    "check:file-health": "node scripts/check-file-health.mjs",
    "typecheck": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run check:file-health && npm run test && npm run eval:rag-contract && npm run build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v",
    "healthcheck": "node -e \"const base=process.env.APP_URL || 'http://localhost:3000'; fetch(base + '/api/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\"",
    "verify:milestone1": "bash scripts/verify-milestone1.sh"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.103.0",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.76.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "next": "^16.2.3",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.9",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
